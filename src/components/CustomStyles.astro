---
// Google Fonts: Poppins (headings) + Roboto (body)
// Loaded via <link> in Layout.astro head
---

<style is:inline>
  :root {
    /* Fonts */
    --aw-font-sans: 'Roboto', ui-sans-serif, system-ui, sans-serif;
    --aw-font-serif: 'Roboto', ui-serif, serif;
    --aw-font-heading: 'Poppins', ui-sans-serif, system-ui, sans-serif;

    /* PFC Brand Colours — purple/blue fitness & care palette */
    --aw-color-primary: rgb(88 28 220);        /* vibrant purple */
    --aw-color-secondary: rgb(59 130 246);      /* bright blue */
    --aw-color-accent: rgb(139 92 246);         /* medium violet */

    --pfc-purple-deep: rgb(76 29 149);         /* deep purple */
    --pfc-purple-mid: rgb(124 58 237);         /* mid purple */
    --pfc-purple-light: rgb(196 181 253);      /* soft lavender */
    --pfc-blue-mid: rgb(37 99 235);            /* cobalt blue */
    --pfc-blue-light: rgb(147 197 253);        /* sky blue */
    --pfc-gradient-start: rgb(88 28 220);
    --pfc-gradient-end: rgb(37 99 235);

    /* Text */
    --aw-color-text-heading: rgb(15 10 40);
    --aw-color-text-default: rgb(30 27 60);
    --aw-color-text-muted: rgb(100 90 140);

    /* Backgrounds */
    --aw-color-bg-page: rgb(252 251 255);
    --aw-color-bg-page-dark: rgb(8 5 30);

    ::selection {
      background-color: rgb(196 181 253);
      color: rgb(76 29 149);
    }
  }
</style>
