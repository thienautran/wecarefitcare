---
import Layout from '~/layouts/Layout.astro';
import Navbar from '~/components/pfc/Navbar';
import HeroCarousel from '~/components/pfc/HeroCarousel';
import AboutSection from '~/components/pfc/AboutSection';
import ServicesTabbedSection from '~/components/pfc/ServicesTabbedSection';
import WhatYouGetSection from '~/components/pfc/WhatYouGetSection';
import TestimonialsSection from '~/components/pfc/TestimonialsSection';
import ContactSection from '~/components/pfc/ContactSection';
import Footer from '~/components/pfc/Footer';

const metadata = {
  title: 'Project Fitcare — NDIS Fitness Support',
  description:
    'NDIS fitness and activity support that delivers real, tangible outcomes through practical hands-on care. Project Fitcare helps you stay active, healthy, and independent.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Sticky navigation -->
  <Navbar client:load />

  <!-- Main content -->
  <main>
    <!-- Hero section with carousel -->
    <HeroCarousel client:load />

    <!-- Who We Are section -->
    <AboutSection client:visible />

    <!-- Our Services section -->
    <ServicesTabbedSection client:visible />

    <!-- What You Get section -->
    <WhatYouGetSection client:visible />

    <!-- Testimonials section -->
    <TestimonialsSection client:visible />

    <!-- Contact Us section -->
    <ContactSection client:visible />
  </main>

  <!-- Footer -->
  <Footer client:visible />
</Layout>
