---
import Layout from '~/layouts/Layout.astro';
import Navbar from '~/components/wcfc/Navbar';
import HeroCarousel from '~/components/wcfc/HeroCarousel';
import AboutSection from '~/components/wcfc/AboutSection';
import ServicesSection from '~/components/wcfc/ServicesSection';
import WhatYouGetSection from '~/components/wcfc/WhatYouGetSection';
import TestimonialsSection from '~/components/wcfc/TestimonialsSection';
import ContactSection from '~/components/wcfc/ContactSection';
import Footer from '~/components/wcfc/Footer';

const metadata = {
  title: 'We Care Fit Care — NDIS Fitness Support',
  description:
    'NDIS fitness and activity support that delivers real, tangible outcomes through practical hands-on care. We Care Fit Care helps you stay active, healthy, and independent.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Sticky navigation -->
  <Navbar client:load />

  <!-- Main content -->
  <main>
    <!-- Hero section with carousel -->
    <HeroCarousel client:load />

    <!-- Who We Are section -->
    <AboutSection client:visible />

    <!-- Our Services section -->
    <ServicesSection client:visible />

    <!-- What You Get section -->
    <WhatYouGetSection client:visible />

    <!-- Testimonials section -->
    <TestimonialsSection client:visible />

    <!-- Contact Us section -->
    <ContactSection client:visible />
  </main>

  <!-- Footer -->
  <Footer client:visible />
</Layout>
